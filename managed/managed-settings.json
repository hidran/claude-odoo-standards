{
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf:*)",
      "Read(./**/.env)",
      "Read(./**/*credentials*)",
      "Read(./**/id_rsa)",
      "WebFetch"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(docker:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/secret-scan-guard.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/run-odoo-lint.sh" }
        ]
      }
    ]
  },
  "strictPluginOnlyCustomization": false
}
