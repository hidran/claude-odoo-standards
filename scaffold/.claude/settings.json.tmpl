{
  "permissions": {
    "allow": [
      "Bash(pre-commit:*)",
      "Bash(python -m pytest:*)",
      "Read(./vendor/odoo/**)"
    ]
  },
  "extraKnownMarketplaces": {
    "claude-odoo-standards": {
      "source": {
        "source": "github",
        "repo": "{{MARKETPLACE}}"
      }
    }
  },
  "enabledPlugins": {
    "odoo-standards@claude-odoo-standards": true,
    "odoo-devkit@claude-odoo-standards": true
  }
}
