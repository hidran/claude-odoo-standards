{
  "permissions": {
    "allow": [
      "Bash(pre-commit:*)",
      "Bash(python -m pytest:*)",
      "Read(./vendor/odoo/**)"
    ]
  },
  "env": { "ODOO_TEST_TAGS": "post_install,-at_install" },
  "extraKnownMarketplaces": {
    "claude-odoo-standards": {
      "source": { "source": "github", "repo": "hidran/claude-odoo-standards" }
    }
  },
  "enabledPlugins": {
    "odoo-standards@claude-odoo-standards": true,
    "odoo-devkit@claude-odoo-standards": true
  }
}
