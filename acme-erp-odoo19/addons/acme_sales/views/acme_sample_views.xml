<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Odoo 18/19: el tag raíz de lista es <list>, NO <tree> -->
    <record id="acme_sample_view_list" model="ir.ui.view">
        <field name="name">acme.sample.list</field>
        <field name="model">acme.sample</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="amount"/>
                <field name="state" decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="acme_sample_view_form" model="ir.ui.view">
        <field name="name">acme.sample.form</field>
        <field name="model">acme.sample</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- 17+: invisible inline, NO attrs="{...}" -->
                    <button name="action_done" type="object" string="Mark Done"
                            class="btn-primary" invisible="state == 'done'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="amount"/>
                        <!-- 17+: readonly inline -->
                        <field name="note" readonly="state == 'done'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 18/19: view_mode usa list, NO tree -->
    <record id="acme_sample_action" model="ir.actions.act_window">
        <field name="name">ACME Samples</field>
        <field name="res_model">acme.sample</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="acme_sample_menu_root" name="ACME"/>
    <menuitem id="acme_sample_menu" name="Samples"
              parent="acme_sample_menu_root" action="acme_sample_action"/>
</odoo>
